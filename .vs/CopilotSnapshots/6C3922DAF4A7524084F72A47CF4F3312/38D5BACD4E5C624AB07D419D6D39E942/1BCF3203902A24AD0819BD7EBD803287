function renderTransactions() {
  const list = document.getElementById("transactionsList");
  const rows = getFilteredTransactions();

  list.innerHTML = rows.length
    ? rows
        .map(
          (order) => `
            <article class="transaction-row">
              <div class="topline">
                <div>
                  <span class="table-tag">${order.customer}</span>
                  <h3>${order.phone}</h3>
                </div>
                <strong class="table-price">${formatRwf(order.amount)}</strong>
              </div>
              <p>${getOrderItemsLabel(order)}</p>
              <div class="bottomline">
                <p>${order.time}</p>
                <span class="table-badge table-${getStatusClass(order.status)}">${order.status}</span>
              </div>
            </article>
          `
        )
        .join("")
    : `<div class="empty-state">No transactions match this search and filter combination.</div>`;
}

