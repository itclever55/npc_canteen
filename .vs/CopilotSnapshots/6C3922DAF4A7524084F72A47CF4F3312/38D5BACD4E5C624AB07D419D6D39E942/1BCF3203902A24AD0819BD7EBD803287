  const productManager = document.getElementById("productManager");

  productManager.innerHTML = state.products
    .map(
      (product) => `
        <article class="manager-card">
          <div class="topline">
            <div class="product-meta">
              <div class="cart-thumb ${product.artClass}"></div>
              <div>
                <h3>${product.name}</h3>
                <p>${formatRwf(product.price)} · Stock ${product.stock}</p>
              </div>
            </div>
