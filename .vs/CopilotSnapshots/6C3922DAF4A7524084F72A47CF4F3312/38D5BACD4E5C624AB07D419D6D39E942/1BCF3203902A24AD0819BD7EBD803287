function renderOverview() {
  const metrics = document.getElementById("overviewMetrics");
  const recentOrders = document.getElementById("recentOrders");
  const stats = getOverviewStats();

  document.getElementById("overviewSales").textContent = formatRwf(stats.totalSales);
  document.getElementById("bestSeller").textContent = stats.bestSeller;
  document.getElementById("topPayment").textContent = stats.topPayment;

  metrics.innerHTML = `
    <article class="metric-card">
      <span>Total orders</span>
      <strong>${stats.orderCount}</strong>
    </article>
    <article class="metric-card">
      <span>Items sold</span>
      <strong>${stats.itemsSold}</strong>
    </article>
    <article class="metric-card">
      <span>Average order</span>
      <strong>${formatRwf(stats.averageOrder)}</strong>
    </article>
    <article class="metric-card">
      <span>Open orders</span>
      <strong>${getOpenOrders().length}</strong>
    </article>
  `;

  recentOrders.innerHTML = state.orders
    .slice(0, 4)
    .map(
      (order) => `
        <article class="transaction-row">
          <div class="topline">
            <div>
              <h3>${order.reference}</h3>
              <p>${getOrderItemsLabel(order)}</p>
            </div>
            <span class="table-badge table-${getStatusClass(order.status)}">${order.status}</span>
          </div>
          <div class="bottomline">
            <p>${order.time}</p>
            <strong class="table-price">${formatRwf(order.amount)}</strong>
          </div>
        </article>
      `
    )
    .join("");
}

function renderAlerts() {
  const alertsList = document.getElementById("alertsList");
  const newOrders = state.orders.filter((order) => order.status === "New");

  alertsList.innerHTML = newOrders.length
    ? newOrders
        .map(
          (order) => `
            <article class="alert-card new-alert">
              <div class="topline">
                <div>
                  <span class="status-badge status-new">NEW</span>
                  <h3>${order.reference}</h3>
                </div>
                <strong class="table-price">${formatRwf(order.amount)}</strong>
              </div>
              <p>${getOrderItemsLabel(order)}</p>
              <div class="bottomline">
                <p>${order.time}</p>
                <p>${order.phone}</p>
              </div>
              <div class="alert-actions">
                <button class="secondary-btn" type="button" data-alert-action="pending" data-reference="${order.reference}">
