const state = {
  currentScreen: "portal",
  pin: "",
  selectedCategory: "all",
  searchQuery: "",
  paymentMethod: "MTN Mobile Money",
  transactionQuery: "",
  transactionFilter: "all",
  exportRange: "today",
  exportStatus: "all",
  nextReference: 847400,
  products: [],
  cart: [
    { productId: "chicken-plate", qty: 1 },
    { productId: "juice-500", qty: 1 },
    { productId: "isabuni", qty: 1 },
  ],
  orders: [],
};

const screens = [...document.querySelectorAll(".screen")];
const switchButtons = [...document.querySelectorAll(".switch-btn")];
const routeButtons = [...document.querySelectorAll("[data-link]")];
const switcher = document.getElementById("screenSwitcher");
const toggleSwitcherBtn = document.getElementById("toggleSwitcher");
const closeSwitcherBtn = document.getElementById("closeSwitcher");
const pinDots = [...document.querySelectorAll("#pinDots span")];
const pinDotsWrap = document.getElementById("pinDots");

function formatRwf(value) {
  return `${Number(value).toLocaleString("en-US")} RWF`;
}

function getProduct(productId) {
  return state.products.find((product) => product.id === productId);
}

function getCartItems() {
  return state.cart
    .map((entry) => {
      const product = getProduct(entry.productId);
      if (!product) return null;

      return {
        ...entry,
        product,
        total: product.price * entry.qty,
      };
    })
    .filter(Boolean);
}

function getSubtotal() {
  return getCartItems().reduce((sum, item) => sum + item.total, 0);
}

function getOrderItemsLabel(order) {
  return order.items
    .map((item) => {
      const product = getProduct(item.productId);
      if (!product) return `${item.qty} item`;
      return `${product.name}${item.qty > 1 ? ` x${item.qty}` : ""}`;
    })
    .join(", ");
}

function getStatusClass(status) {
  const normalized = status.toLowerCase();
  if (normalized === "paid") return "paid";
  if (normalized === "pending") return "pending";
  return "new";
}

function getVisibleProducts() {
  return state.products.filter((product) => {
    const matchesEnabled = product.enabled;
    const matchesCategory =
      state.selectedCategory === "all" || product.category === state.selectedCategory;
    const query = state.searchQuery.trim().toLowerCase();
    const matchesQuery =
      !query ||
      product.name.toLowerCase().includes(query) ||
      product.localName.toLowerCase().includes(query) ||
      product.description.toLowerCase().includes(query);

    return matchesEnabled && matchesCategory && matchesQuery;
  });
}

function getOpenOrders() {
  return state.orders.filter((order) => order.status !== "Paid");
}

function getFilteredTransactions() {
  return state.orders.filter((order) => {
    const query = state.transactionQuery.trim().toLowerCase();
    const statusMatches =
      state.transactionFilter === "all" ||
      (state.transactionFilter === "paid" && order.status === "Paid") ||
      (state.transactionFilter === "pending" && order.status !== "Paid");
    const queryMatches =
      !query ||
      order.phone.toLowerCase().includes(query) ||
      getOrderItemsLabel(order).toLowerCase().includes(query);

    return statusMatches && queryMatches;
  });
}

function getExportOrders() {
  return state.orders.filter((order) => {
    const rangeMatches =
      state.exportRange === "month" ||
      (state.exportRange === "week" && (order.period === "today" || order.period === "week")) ||
      (state.exportRange === "today" && order.period === "today");

    const statusMatches =
      state.exportStatus === "all" ||
      (state.exportStatus === "paid" && order.status === "Paid") ||
      (state.exportStatus === "pending" && order.status !== "Paid");

    return rangeMatches && statusMatches;
  });
}

function getOverviewStats() {
  const todayOrders = state.orders.filter((order) => order.period === "today");
  const sourceOrders = todayOrders.length ? todayOrders : state.orders;
  const totalSales = sourceOrders.reduce((sum, order) => sum + order.amount, 0);
  const itemsSold = sourceOrders.reduce(
    (sum, order) => sum + order.items.reduce((count, item) => count + item.qty, 0),
    0
  );
  const averageOrder = sourceOrders.length ? Math.round(totalSales / sourceOrders.length) : 0;
  const bestSellerMap = new Map();
  const paymentMap = new Map();

  sourceOrders.forEach((order) => {
    paymentMap.set(order.payment, (paymentMap.get(order.payment) || 0) + 1);
    order.items.forEach((item) => {
      const product = getProduct(item.productId);
      if (!product) return;
      bestSellerMap.set(product.name, (bestSellerMap.get(product.name) || 0) + item.qty);
    });
  });

  const bestSeller = [...bestSellerMap.entries()].sort((a, b) => b[1] - a[1])[0]?.[0] || "-";
  const topPayment = [...paymentMap.entries()].sort((a, b) => b[1] - a[1])[0]?.[0] || "-";

  return {
    totalSales,
    orderCount: sourceOrders.length,
    itemsSold,
    averageOrder,
    bestSeller,
    topPayment,
  };
}

function setSwitcherOpen(isOpen) {
  if (!switcher || !toggleSwitcherBtn) return;
  switcher.classList.toggle("open", isOpen);
  switcher.setAttribute("aria-hidden", String(!isOpen));
  toggleSwitcherBtn.setAttribute("aria-expanded", String(isOpen));
}

function showScreen(screenId) {
  state.currentScreen = screenId;

  screens.forEach((screen) => {
    screen.classList.toggle("active", screen.id === screenId);
  });

  switchButtons.forEach((btn) => {
    btn.classList.toggle("active", btn.dataset.screen === screenId);
  });

  document.querySelectorAll(".bottom-nav button[data-link]").forEach((btn) => {
    const parentScreen = btn.closest(".screen");
    if (!parentScreen) return;

    btn.classList.toggle(
      "on",
      btn.dataset.link === screenId && parentScreen.classList.contains("active")
    );
  });

  window.location.hash = screenId;
  setSwitcherOpen(false);
}

function renderShop() {
  const productGrid = document.getElementById("productGrid");
  const products = getVisibleProducts();

  productGrid.innerHTML = products.length
    ? products
        .map(
          (product) => `
            <article class="product-card">
              <div class="product-art ${product.artClass}"></div>
              <div class="product-meta">
                <div>
                  <h3 class="product-name">${product.name}</h3>
                  <p class="product-sub">${product.localName}</p>
                </div>
                <strong>${formatRwf(product.price)}</strong>
              </div>
              <p>${product.description}</p>
              <div class="card-actions">
                <button class="secondary-btn" type="button">${product.category}</button>
                <button class="primary-btn add-to-cart" type="button" data-product-id="${product.id}">
                  + Add
                </button>
              </div>
            </article>
          `
        )
        .join("")
    : `<div class="empty-state">No visible products match this filter. Enable more products in Trader Products.</div>`;

  const cartCount = state.cart.reduce((sum, item) => sum + item.qty, 0);
  document.querySelectorAll('.customer-nav button[data-link="cart"]').forEach((button) => {
    button.textContent = cartCount ? `Cart (${cartCount})` : "Cart";
  });
}

function renderCart() {
  const cartList = document.getElementById("cartList");
  const cartItems = getCartItems();
  const subtotal = getSubtotal();
  const total = subtotal + 50;

  cartList.innerHTML = cartItems.length
    ? cartItems
        .map(
          (item) => `
            <article class="cart-card">
              <div class="cart-thumb ${item.product.artClass}"></div>
              <div class="cart-copy">
                <div class="product-meta">
                  <div>
                    <h3>${item.product.name}</h3>
                    <p>${item.product.localName}</p>
                  </div>
                  <strong>${formatRwf(item.product.price)}</strong>
                </div>
                <div class="qty-wrap">
                  <button class="qty-btn" type="button" data-cart-product="${item.product.id}" data-change="-1">-</button>
                  <span class="qty-badge">${item.qty}</span>
                  <button class="qty-btn" type="button" data-cart-product="${item.product.id}" data-change="1">+</button>
                </div>
              </div>
            </article>
          `
        )
        .join("")
    : `<div class="empty-state">Your cart is empty. Add products from the customer home screen.</div>`;

  document.getElementById("subtotal").textContent = formatRwf(subtotal);
  document.getElementById("total").textContent = formatRwf(total);

  document.querySelectorAll(".pay-option").forEach((button) => {
    button.classList.toggle("active", button.dataset.payment === state.paymentMethod);
  });
}

function renderOrders() {
  const ordersList = document.getElementById("ordersList");

  ordersList.innerHTML = state.orders.length
    ? state.orders
        .map(
          (order) => `
            <article class="order-card">
              <div class="topline">
                <div>
                  <h3>${order.reference}</h3>
                  <p>${getOrderItemsLabel(order)}</p>
                </div>
                <div class="status-row">
                  <strong class="table-price">${formatRwf(order.amount)}</strong>
                  <span class="status-badge status-${getStatusClass(order.status)}">${order.status}</span>
                </div>
              </div>
              <div class="bottomline">
                <p>${order.payment}</p>
                <p>${order.time}</p>
              </div>
            </article>
          `
        )
        .join("")
