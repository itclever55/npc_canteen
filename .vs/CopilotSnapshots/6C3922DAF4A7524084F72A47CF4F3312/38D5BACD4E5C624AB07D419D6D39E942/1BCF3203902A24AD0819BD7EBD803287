              class="toggle-pill ${product.enabled ? "on" : "off"}"
              type="button"
              data-product-toggle="${product.id}"
            >
              ${product.enabled ? "ON" : "OFF"}
            </button>
          </div>
          <p>${product.localName}</p>
          <div class="manager-actions">
            <button class="secondary-btn" type="button" data-product-edit="${product.id}">Edit Price</button>
